{
  "name": "wellness-widget",
  "private": true,
  "version": "1.0.0",
  "description": "твой день — floating macOS wellness widget",
  "author": "m1xxos",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "vite build && electron .",
    "app:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dist": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.11"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  },
  "build": {
    "appId": "com.welldged.wellness",
    "productName": "твой день",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    }
  }
}
